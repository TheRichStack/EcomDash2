# App metadata
NEXT_PUBLIC_APP_NAME=EcomDash2
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Backend
ECOMDASH2_BACKEND_SOURCE=turso
ECOMDASH2_TURSO_URL=
ECOMDASH2_TURSO_AUTH_TOKEN=
ECOMDASH2_DB_DEFAULT_LIMIT=25000
ECOMDASH2_DEFAULT_CURRENCY=GBP

# Workspace and local session defaults
ECOMDASH2_DEFAULT_WORKSPACE_ID=default
ECOMDASH2_DEFAULT_WORKSPACE_LABEL=Default workspace
ECOMDASH2_WORKSPACE_OPTIONS=default:Default workspace
ECOMDASH2_SESSION_USER_ID=local-admin
ECOMDASH2_SESSION_EMAIL=

# Agentic brain
DATA_ENCRYPTION_KEY=
ECOMDASH2_AGENT_EXECUTOR_URL=
ECOMDASH2_AGENT_ENABLE_WORKER=0
ECOMDASH2_AGENT_SHARED_SECRET=
ECOMDASH2_AGENT_ROUTER_MODEL_OPENAI=
ECOMDASH2_AGENT_ROUTER_MODEL_ANTHROPIC=
ECOMDASH2_AGENT_DEFAULT_OPENAI_MODEL=gpt-5.4
ECOMDASH2_AGENT_DEFAULT_ANTHROPIC_MODEL=claude-sonnet-4-5
ECOMDASH2_AGENT_SQL_MAX_ROWS=500
ECOMDASH2_AGENT_DATASET_ROW_LIMIT=200
ECOMDASH2_AGENT_BUDGET_USD_PER_DAY=5
ECOMDASH2_AGENT_BUDGET_USD_PER_MONTH=250
ECOMDASH2_AGENT_LAB_BUDGET_USD_PER_RUN=2
ECOMDASH2_AGENT_ALLOW_INLINE_OPS=0
