# App metadata
NEXT_PUBLIC_APP_NAME=EcomDash2
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Backend
ECOMDASH2_BACKEND_SOURCE=turso
ECOMDASH2_TURSO_URL=
ECOMDASH2_TURSO_AUTH_TOKEN=
ECOMDASH2_DB_DEFAULT_LIMIT=25000
